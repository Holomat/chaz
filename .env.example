# Variables de entorno (configurar en Vercel → Project → Settings → Environment Variables)
# Son OPCIONALES: si no se setean, se usan los valores por defecto del código.
# Recomendado setearlas en producción para no depender de los defaults del repo.

# Contraseña de acceso
ACCESS_PASSWORD=comunicacion

# Valor secreto de la cookie de sesión (cambiá esto por una cadena larga y aleatoria).
# DEBE ser el mismo que usa el middleware (si lo cambiás acá, Vercel lo inyecta en ambos).
SESSION_TOKEN=cambiar-por-una-cadena-larga-y-aleatoria

# Dominio de correo permitido
ALLOWED_DOMAIN=mec.gub.uy
